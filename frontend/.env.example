# Frontend Environment Variables
# Vite loads .env.development or .env.production automatically by mode.
# Create a .env file (gitignored) for local overrides.
# Only VITE_* variables are exposed to the browser.

# API Configuration
# Must match the backend route prefix (currently /api/v1).
# In dev, the Vite proxy forwards /api → backend.
# In prod, nginx does the same.
VITE_API_BASE_URL=/api/v1

# App Configuration
VITE_APP_TITLE=ArticNexus
VITE_APP_ENVIRONMENT=development

# External product URLs (used by the public landing page)
VITE_VETDATA_URL=https://vetdata.example.com
VITE_OFTADATA_URL=https://oftadata.example.com