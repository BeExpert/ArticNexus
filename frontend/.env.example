# Frontend Environment Variables
# Copy to .env.development / .env.production or .env for local overrides.
# Only VITE_* variables are exposed to the browser.

# API Configuration
# In dev, the Vite proxy forwards /api → backend, so the path is relative.
# In prod, nginx does the same forwarding.
VITE_API_BASE_URL=/api/v1

# App Configuration
VITE_APP_TITLE=ArticNexus

# External product URLs (used by the public landing page)
VITE_VETDATA_URL=https://vetdata.example.com
VITE_OFTADATA_URL=https://oftadata.example.com