# Backend Environment Variables

# Application
# APP_PORT / APP_ENV are preferred. PORT / ENVIRONMENT are still accepted as fallback.
APP_PORT=8080
APP_ENV=development
# PORT=8080
# ENVIRONMENT=development

# Database (PostgreSQL)
# Option A: full DSN (takes precedence if set)
DATABASE_URL=

# Option B: split DB_* variables (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=articnexus
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=60

# Migrations directory (relative to backend/ execution path)
MIGRATIONS_DIR=../database/migrations

# JWT
JWT_SECRET=change-me-in-production
JWT_EXP_HOURS=24

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Bootstrap super admin (optional)
# If either SUPER_ADMIN_USER or SUPER_ADMIN_PASS is empty, bootstrap is skipped.
SUPER_ADMIN_USER=admin
SUPER_ADMIN_PASS=change-me
SUPER_ADMIN_FORCE=0
BCRYPT_COST=12

# Frontend/product URLs for links in emails
FRONTEND_URL=http://localhost:5173
OFTADATA_URL=http://localhost:5174
VETDATA_URL=http://localhost:5175

# Shared SMTP transport
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Support account: password reset and tickets
SUPPORT_SMTP_USER=support@example.com
SUPPORT_SMTP_PASSWORD=app-password-here
SUPPORT_SMTP_FROM=Support Team <support@example.com>

# Business account: contact/proposals
BUSINESS_SMTP_USER=business@example.com
BUSINESS_SMTP_PASSWORD=app-password-here
BUSINESS_SMTP_FROM=Business Team <business@example.com>

# Contact form destination (if empty, backend can fallback to business account)
CONTACT_EMAIL=business@example.com

# Password reset token expiration (minutes)
PASSWORD_RESET_EXP_MIN=30

# Log rotation
LOG_MAX_SIZE_MB=10
LOG_MAX_BACKUPS=3

# Legacy / currently unused by backend config (kept here only as reference)
# DB_DRIVER=postgres
# LOG_LEVEL=debug
# SSL_ENABLED=false
# SSL_CERT_FILE=
# SSL_KEY_FILE=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=