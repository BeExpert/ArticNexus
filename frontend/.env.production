# Production — used by `npm run build`
# nginx proxies /api → backend, so the path stays relative.
VITE_API_BASE_URL=/api/v1
VITE_APP_TITLE=ArticNexus
VITE_APP_ENVIRONMENT=production

# External product URLs (adjust to real domains)
VITE_VETDATA_URL=https://articdev.com
VITE_OFTADATA_URL=https://articdev.com
